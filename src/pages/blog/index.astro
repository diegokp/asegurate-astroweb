---
import Layout from '~/layouts/Layout.astro';
import HeaderTop from '~/components/headerTop.astro';
import Header from '~/components/header.astro';
import Whatsapp from '~/components/whatsapp.astro';
import Footer from '~/components/footer.astro'
import CardBlog from '~/components/cardBlog.astro';
import Articulos from '~/components/articulos.vue'

import type { CollectionEntry } from 'astro:content';
import { getCollection } from "astro:content";

const posts = (
  await getCollection(
    'blog',
    ({ data }: CollectionEntry<'blog'>) => data.last == false
  )
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const postsDraft = (
  await getCollection(
    'blog',
    ({ data }: CollectionEntry<'blog'>) => data.last == true
  )
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const siteURL = "https://www.aseguratte.es";
const blogURL = `${siteURL}/blog`;

const allPosts = [...postsDraft, ...posts];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${blogURL}/#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteURL },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": blogURL }
      ]
    },
    {
      "@type": "Blog",
      "@id": `${blogURL}/#blog`,
      "name": "Blog de Seguros — Asegura-Te",
      "description": "Consejos, artículos y novedades sobre seguros para particulares y empresas en Las Palmas de Gran Canaria.",
      "url": blogURL,
      "inLanguage": "es",
      "publisher": {
        "@type": "Organization",
        "@id": `${siteURL}/#agency`,
        "name": "Asegura-Te"
      },
      "blogPost": allPosts.map(post => ({
        "@type": "BlogPosting",
        "headline": post.data.title.replace(/^[\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}]+\s*/gu, '').trim(),
        "url": `${siteURL}/blog/${post.id}`,
        "datePublished": (post.data.publishDate instanceof Date
          ? post.data.publishDate
          : new Date(post.data.publishDate)).toISOString(),
        "image": post.data.image.startsWith('http') ? post.data.image : `${siteURL}${post.data.image}`
      }))
    }
  ]
};
---

<Layout
	title="Blog de Seguros — Consejos y Artículos"
	description="Artículos y consejos sobre seguros para particulares y empresas en Las Palmas. Aprende a proteger lo que más te importa con Asegura-Te."
	canonicalURL={blogURL}
	ogImage={`${siteURL}/images/asegurate_logoW.png`}
	>
	<script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(jsonLd)} />
	<Whatsapp />
	<section id="inicio">
		<HeaderTop />
		<Header />
	</section>
	<section>
      <main>
    	<h1>Últimos artículos</h1>
    	</main>
    	<main>
        <Articulos client:only="vue"></Articulos>
    	</main>
	</section>
	<Footer />
</Layout>


<style>

    main{
        width: 85%;
        margin: 40px auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 40px;
    }

    main > div{
        width: 100%;
    }


    main > img{
        width: 80%;
        max-width: 900px;
    }


    @media only screen and (max-width: 900px)  {
        main > img{
            width: 100%;
        }
    }

</style>
