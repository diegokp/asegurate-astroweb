---
import Layout from '~/layouts/Layout.astro';
import HeaderTop from '~/components/headerTop.astro';
import Header from '~/components/header.astro';
import Whatsapp from '~/components/whatsapp.astro';
import Footer from '~/components/footer.astro';
import SegurosPage from '~/components/segurosPage.astro';
// import Tarificador from '~/components/tarificador.astro';
import ContactForm from '~/components/contactForm.astro';
import SegurosLink from '~/components/segurosLink.astro';
import { buildServiceSchema, siteURL } from '~/utils/schema';

const pageURL = `${siteURL}/seguro-las-palmas/hogar/`;
const jsonLd = buildServiceSchema({
  pageURL,
  name: "Seguros de Hogar en Las Palmas",
  description: "Asesoramiento y contratación de seguro de hogar para vivienda habitual, segunda residencia o alquiler en Las Palmas de Gran Canaria. Comparativa de coberturas y compañías.",
  serviceType: "Home insurance",
  breadcrumbName: "Seguro de Hogar",
  faqs: [
    { question: "¿Qué cubre normalmente un seguro de hogar?", answer: "Suele incluir daños en el continente (estructura) y/o contenido (mobiliario), responsabilidad civil del hogar, asistencia 24h y coberturas opcionales como daños por agua, incendio o robo, según póliza y compañía." },
    { question: "¿Cuál es la diferencia entre continente y contenido?", answer: "El continente es la estructura de la vivienda (paredes, suelos, instalaciones fijas), y el contenido son los bienes dentro del hogar (muebles, electrodomésticos, objetos personales)." },
    { question: "¿Necesito seguro de hogar si tengo hipoteca?", answer: "Por ley no es obligatorio, pero la entidad financiera suele exigir cobertura para el continente. Conviene revisar condiciones y comparar opciones fuera del banco." },
    { question: "¿Se puede asegurar una vivienda en alquiler?", answer: "Sí. El propietario puede asegurar el continente y la responsabilidad civil; el inquilino puede asegurar su contenido y RC como arrendatario según sus necesidades." },
    { question: "¿Cómo se calcula el capital asegurado del contenido?", answer: "Se estima según el valor de reposición de los bienes. Un inventario básico ayuda a evitar infraseguro o sobreseguro." }
  ]
});
---

<Layout
	title="Seguros de Hogar en Las Palmas"
	description='Protege tu hogar con Asegura-Te, tu correduría de Seguros en Las Palmas. Seguros para todo tipo de viviendas en Gran Canaria.'
	canonicalURL={pageURL}
	>
	<script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(jsonLd)} />
	<Whatsapp />
	<section id="inicio">
		<HeaderTop />
		<Header />
	</section>
	<SegurosPage
        title='Seguros de Hogar en Las Palmas'
        url="/images/hogar_dest.webp"
        alt="Seguros de Hogar en Las Palmas"
        href="#avantContainer"
        subtitle='Protege tu hogar con nuestros seguros en Las Palmas'
        subsubtitle="¿Por qué elegirnos para asegurar tu hogar?"
        >
        <p slot="after-title">
            En Asegura-Te entendemos que tu hogar es tu refugio, por eso ofrecemos seguros de hogar personalizados en Las Palmas para protegerlo en todo momento. Nuestro equipo de expertos en seguros está dedicado a encontrar la mejor cobertura para ti, asegurando que tu hogar y tus pertenencias estén protegidos contra cualquier imprevisto. Con una amplia gama de opciones de cobertura y tarifas competitivas, puedes estar tranquilo sabiendo que estamos aquí para cuidar de tu hogar como si fuera el nuestro.
        </p>
        <p slot="after-subtitle">
            En Asegura-Te nos preocupamos por tu seguridad y bienestar en el hogar. Nuestros seguros de hogar están diseñados para brindarte la protección que necesitas, desde daños por agua o incendio hasta robos o responsabilidad civil. Además, con nuestro equipo de profesionales a tu disposición, puedes estar seguro de que recibirás el mejor servicio y atención en caso de necesitar asistencia. No dejes nada al azar cuando se trata de la seguridad de tu hogar, confía en Asegura-Te para proteger lo que más importa.
        </p>
        <p slot="after-subsubtitle">
            En Asegura-Te nos comprometemos a ofrecerte seguros de hogar adaptados a tus necesidades, con coberturas amplias y precios competitivos. Además, nuestro equipo de profesionales estará contigo en cada paso del proceso para brindarte el mejor servicio.
        </p>
    </SegurosPage>
    <ContactForm  page="Hogar"/>
    <!-- <Tarificador name="hogar"/> -->
    <SegurosLink
    hrefFrom='/seguro-las-palmas/flotas/'
    titleFrom='Flotas'
    hrefTo='/seguro-las-palmas/mascotas/'
    titleTo='Mascotas'
    />

	<Footer />
</Layout>
