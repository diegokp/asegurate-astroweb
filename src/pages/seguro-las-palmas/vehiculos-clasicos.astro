---
import Layout from '~/layouts/Layout.astro';
import HeaderTop from '~/components/headerTop.astro';
import Header from '~/components/header.astro';
import Whatsapp from '~/components/whatsapp.astro';
import Footer from '~/components/footer.astro';
import SegurosPage from '~/components/segurosPage.astro';
import SegurosLink from '~/components/segurosLink.astro';
import { buildServiceSchema, siteURL } from '~/utils/schema';

const pageURL = `${siteURL}/seguro-las-palmas/vehiculos-clasicos/`;
const jsonLd = buildServiceSchema({
  pageURL,
  name: "Seguros para Vehículos Clásicos en Las Palmas",
  description: "Seguros de vehículos clásicos en Las Palmas de Gran Canaria. Pólizas específicas para coches de colección con más de 25 años. Valor acordado, cobertura en concentraciones y prima reducida.",
  serviceType: "Classic car insurance",
  breadcrumbName: "Vehículos Clásicos"
});
---

<Layout
	title="Seguros para Vehículos Clásicos en Las Palmas"
	description='Protege tu vehículo clásico con nuestros seguros específicos para coches clásicos en Las Palmas con Asegura-Te.'
	canonicalURL={pageURL}
	>
	<script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(jsonLd)} />
	<Whatsapp />
	<section id="inicio">
		<HeaderTop />
		<Header />
	</section>
	<SegurosPage
        title='Seguros para Vehículos Clásicos en Las Palmas'
        url="/images/vehiculos-clasicos.webp"
        alt="Seguros para Vehículos Clásicos en Las Palmas"
        href="/contacto/"
        subtitle='Seguros especializados para tus vehículos clásicos'
        subsubtitle="Seguros especializados para tus vehículos clásicos"
        >
        <p slot="after-title">
            En Asegura-Te entendemos tu amor por los vehículos clásicos, por eso ofrecemos seguros para vehículos clásicos en Las Palmas diseñados para proteger tu inversión con estilo. Nuestros planes de cobertura especializada están diseñados para adaptarse a las necesidades únicas de tu vehículo clásico, brindándote la tranquilidad de saber que estás protegido contra daños, robos y otros riesgos. Confía en nosotros para proteger tu vehículo clásico y mantener viva la pasión por los autos antiguos.
        </p>
        <p slot="after-subtitle">
            En Asegura-Te entendemos tu amor por los vehículos clásicos, por eso ofrecemos seguros para vehículos clásicos en Las Palmas diseñados para proteger tu inversión con estilo. Nuestros planes de cobertura especializada están diseñados para adaptarse a las necesidades únicas de tu vehículo clásico, brindándote la tranquilidad de saber que estás protegido contra daños, robos y otros riesgos. Confía en nosotros para proteger tu vehículo clásico y mantener viva la pasión por los autos antiguos.
        </p>
        <p slot="after-subsubtitle">
            En Asegura-Te entendemos tu amor por los vehículos clásicos, por eso ofrecemos seguros para vehículos clásicos en Las Palmas diseñados para proteger tu inversión con estilo. Nuestros planes de cobertura especializada están diseñados para adaptarse a las necesidades únicas de tu vehículo clásico, brindándote la tranquilidad de saber que estás protegido contra daños, robos y otros riesgos. Confía en nosotros para proteger tu vehículo clásico y mantener viva la pasión por los autos antiguos.
        </p>
    </SegurosPage>
    <SegurosLink 
    hrefFrom='/seguro-las-palmas/unit-linked/'
    titleFrom='Unit Linked'
    hrefTo='/seguro-las-palmas/viajes/'
    titleTo='Viajes'
    />
	<Footer />
</Layout>
