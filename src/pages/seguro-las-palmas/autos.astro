---
import Layout from '~/layouts/Layout.astro';
import HeaderTop from '~/components/headerTop.astro';
import Header from '~/components/header.astro';
import Whatsapp from '~/components/whatsapp.astro';
import Footer from '~/components/footer.astro';
import SegurosPage from '~/components/segurosPage.astro';
// import Tarificador from '~/components/tarificador.astro';
import SegurosLink from '~/components/segurosLink.astro';
import ContactForm from '~/components/contactForm.astro';
import { buildServiceSchema, siteURL } from '~/utils/schema';

const pageURL = `${siteURL}/seguro-las-palmas/autos/`;
const jsonLd = buildServiceSchema({
  pageURL,
  name: "Seguros de Autos en Las Palmas",
  description: "Seguros de coche en Las Palmas de Gran Canaria. Comparativa de coberturas a terceros, terceros ampliados y todo riesgo con las mejores compañías.",
  serviceType: "Car insurance",
  breadcrumbName: "Seguro de Autos",
  faqs: [
    { question: "¿Qué coberturas tiene un seguro de coche?", answer: "Desde la responsabilidad civil obligatoria hasta coberturas amplias como daños propios, robo, incendio, lunas, asistencia en carretera y seguro del conductor, según la modalidad." },
    { question: "¿Cuál es la diferencia entre todo riesgo y terceros?", answer: "El seguro a terceros cubre los daños que causas a otros. Todo riesgo añade la cobertura de daños propios de tu vehículo, independientemente de quién sea el culpable del siniestro." },
    { question: "¿Qué incluye la asistencia en carretera?", answer: "Generalmente cubre el remolque del vehículo, ayuda mecánica in situ, taxi de sustitución y, en algunos casos, vehículo de sustitución durante la reparación." },
    { question: "¿Puedo asegurar un coche de segunda mano?", answer: "Sí, cualquier vehículo puede asegurarse independientemente de su antigüedad. La prima dependerá del valor venal, el perfil del conductor y las coberturas elegidas." },
    { question: "¿Es obligatorio el seguro de coche en España?", answer: "Sí, el seguro de responsabilidad civil es obligatorio para circular por vías públicas. Circular sin seguro conlleva sanciones y la retirada del vehículo." }
  ]
});
---

<Layout
	title="Seguros de Autos en Las Palmas"
	description='Seguros de coche en Las Palmas con las mejores garantías. Asegura-Te es tu correduría de seguros de confianza. Te asesoramos y estamos para ayudarte.'
	canonicalURL={pageURL}
	>
	<script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(jsonLd)} />
	<Whatsapp />
	<section id="inicio">
		<HeaderTop />
		<Header />
	</section>
	<SegurosPage
        title='Seguro de Coche en Las Palmas'
        url="/images/autos.webp"
        alt="Seguro de Coche en Las Palmas"
        href="#avantContainer"
        subtitle='Conduce con tranquilidad y seguridad con nuestros seguros de coche en Las Palmas'
        subsubtitle="¿Por qué elegir nuestros seguros de coches en Las Palmas?"
        >
        <p slot="after-title">
            En Asegura-Te comprendemos lo importante que es tu vehículo para ti, por eso ofrecemos seguros de autos en Las Palmas diseñados para brindarte tranquilidad y protección en la carretera. Nuestros planes de cobertura flexible están diseñados para adaptarse a tus necesidades específicas, desde la cobertura básica hasta opciones más completas que incluyen asistencia en carretera y cobertura de accidentes. Confía en nosotros para proteger tu vehículo y disfrutar de la tranquilidad de saber que estás cubierto en caso de imprevistos.
        </p>
        <p slot="after-subtitle">
            Nos comprometemos a proteger lo que más valoras, incluido tu vehículo. Nuestros seguros de autos están diseñados para brindarte la protección que necesitas en la carretera, ya sea que conduzcas un automóvil, una camioneta o una motocicleta. Con una amplia gama de opciones de cobertura y tarifas competitivas, puedes estar tranquilo sabiendo que estás protegido contra los riesgos asociados con la conducción. Confía en nosotros para proteger tu vehículo y disfrutar de la libertad de la carretera sin preocupaciones.
        </p>
        <p slot="after-subsubtitle">
            Nuestros seguros de autos están diseñados para brindarte la mejor protección y tranquilidad al conducir. Confía en nosotros para cuidar de ti y de tu vehículo.
        </p>
    </SegurosPage>
    <ContactForm page="Autos"/>
    <!-- <Tarificador name="autos"/> -->
    <SegurosLink
    hrefFrom='/seguro-las-palmas/accidentes-individual/'
    titleFrom='Accidentes individual'
    hrefTo='/seguro-las-palmas/baja-laboral/'
    titleTo='Baja laboral'
    />
	<Footer />
</Layout>
