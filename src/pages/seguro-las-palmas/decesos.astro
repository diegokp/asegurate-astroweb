---
import Layout from '~/layouts/Layout.astro';
import HeaderTop from '~/components/headerTop.astro';
import Header from '~/components/header.astro';
import Whatsapp from '~/components/whatsapp.astro';
import Footer from '~/components/footer.astro';
import SegurosPage from '~/components/segurosPage.astro';
// import Tarificador from '~/components/tarificador.astro';
import ContactForm from '~/components/contactForm.astro';
import SegurosLink from '~/components/segurosLink.astro';
import { buildServiceSchema, siteURL } from '~/utils/schema';

const pageURL = `${siteURL}/seguro-las-palmas/decesos/`;
const jsonLd = buildServiceSchema({
  pageURL,
  name: "Seguros de Decesos en Las Palmas",
  description: "Seguros de decesos en Las Palmas de Gran Canaria. Cubre los gastos del sepelio y gestiones funerarias para que tu familia no tenga que preocuparse en los momentos más difíciles.",
  serviceType: "Funeral insurance",
  breadcrumbName: "Seguro de Decesos",
  faqs: [
    { question: "¿Qué cubre un seguro de decesos?", answer: "Los gastos derivados del sepelio: ataúd, servicio funerario, traslado del cuerpo, tanatorio, gestiones administrativas y, en muchas pólizas, lapida y nicho." },
    { question: "¿Es lo mismo que un seguro de vida?", answer: "No. El seguro de decesos cubre exclusivamente los gastos del funeral. El seguro de vida paga un capital a los beneficiarios. Son productos complementarios." },
    { question: "¿Se puede contratar para toda la familia?", answer: "Sí, existen modalidades familiares que cubren a todos los miembros del hogar bajo una misma póliza, lo que suele resultar más económico que contratos individuales." },
    { question: "¿Qué pasa si fallezco fuera de España?", answer: "La mayoría de pólizas incluyen cobertura de repatriación desde cualquier país del mundo, incluyendo todos los trámites consulares y el traslado hasta el lugar designado." }
  ]
});
---

<Layout
	title="Seguros de Decesos en Las Palmas"
	description='Protege a tu familia en momentos difíciles con nuestros seguros de decesos en Las Palmas. Asegura-Te: tu correduría de confianza en Gran Canaria.'
	canonicalURL={pageURL}
	>
	<script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(jsonLd)} />
	<Whatsapp />
	<section id="inicio">
		<HeaderTop />
		<Header />
	</section>
    <SegurosPage
        title='Seguros de Decesos en Las Palmas'
        url="/images/decesos_dest.webp"
        alt="Seguros de Decesos en Las Palmas"
        href="#avantContainer"
        subtitle='Tranquilidad y protección para tus seres queridos'
        subsubtitle="¿Por qué elegirnos para asegurar a tu familia en momentos difíciles?"
        >
        <p slot="after-title">
            En Asegura-Te entendemos la importancia de planificar el futuro y proteger a tus seres queridos. Nuestros seguros de decesos en Las Palmas están diseñados para ofrecerte tranquilidad y seguridad en momentos difíciles. Con una amplia gama de opciones de cobertura y tarifas competitivas, puedes estar tranquilo sabiendo que estás protegiendo a tu familia de los costos inesperados asociados con un funeral. Confía en nosotros para proporcionarte la cobertura que necesitas para enfrentar cualquier eventualidad con tranquilidad y paz mental.
        </p>
        <p slot="after-subtitle">
            En Asegura-Te nos preocupamos por aliviar el estrés financiero y emocional en momentos difíciles. Nuestros seguros de decesos están diseñados para brindarte a ti y a tu familia la seguridad y protección que necesitan en momentos de duelo. Con un equipo dedicado a proporcionarte el mejor servicio y atención al cliente, puedes confiar en nosotros para estar a tu lado en los momentos más difíciles. Protege a tus seres queridos y planifica tu futuro con Asegura-Te.
        </p>
        <p slot="after-subsubtitle">
            En Asegura-Te nos comprometemos a brindarte la mejor protección para tu familia en momentos difíciles. Contamos con años de experiencia y un equipo dedicado para ofrecerte el apoyo que necesitas. Confía en nosotros para cuidar de los tuyos.
        </p>
    </SegurosPage>
    <ContactForm  page="Decesos"/>
    <!-- <Tarificador name="decesos"/> -->
    <SegurosLink
    hrefFrom='/seguro-las-palmas/comercios/'
    titleFrom='Comercios'
    hrefTo='/seguro-las-palmas/defensa-juridica-empresa/'
    titleTo='Defensa jurídica empresa'
    />
	<Footer />
</Layout>
