---
import Layout from '~/layouts/Layout.astro';
import HeaderTop from '~/components/headerTop.astro';
import Header from '~/components/header.astro';
import Whatsapp from '~/components/whatsapp.astro';
import Footer from '~/components/footer.astro';
import SegurosPage from '~/components/segurosPage.astro';
import SegurosLink from '~/components/segurosLink.astro';
import { buildServiceSchema, siteURL } from '~/utils/schema';

const pageURL = `${siteURL}/seguro-las-palmas/flotas/`;
const jsonLd = buildServiceSchema({
  pageURL,
  name: "Seguros para Flotas en Las Palmas",
  description: "Seguros de flotas de vehículos en Las Palmas de Gran Canaria. Póliza única para turismos, furgonetas y camiones de empresa. Gestión centralizada y tarifas por volumen.",
  serviceType: "Fleet insurance",
  breadcrumbName: "Seguro de Flotas"
});
---

<Layout
	title="Seguros para Flotas en Las Palmas"
	description='Asegura tu flota de vehículos con nuestros seguros para flotas en Las Palmas. Asegura-Te tiene el seguro indicado para tu empresa.'
	canonicalURL={pageURL}
	>
	<script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(jsonLd)} />
	<Whatsapp />
	<section id="inicio">
		<HeaderTop />
		<Header />
	</section>
    <SegurosPage
        title='Seguros para Flotas en Las Palmas'
        url="/images/flotas.webp"
        alt="Seguros para Flotas en Las Palmas"
        href="/contacto/"
        subtitle='Protección integral para tus flotas de vehículos'
        subsubtitle="¿Por qué elegir nuestros seguros para flotas de vehículos?"
        >
        <p slot="after-title">
			Gestionar una flota de vehículos puede ser un desafío, por eso ofrecemos seguros para flotas en Las Palmas diseñados para brindarte la protección y tranquilidad que necesitas para tu negocio. Nuestros planes de cobertura flexible están diseñados para adaptarse a las necesidades específicas de tu flota, brindándote la tranquilidad de saber que estás protegido contra los riesgos asociados con la conducción y el mantenimiento de múltiples vehículos. Confía en nosotros para proteger tu flota y mantener tu negocio en movimiento con total seguridad.
        </p>
        <p slot="after-subtitle">
            Nos dedicamos a proporcionarte la mejor protección para tu flota de vehículos. Nuestros seguros para flotas están diseñados para brindarte la cobertura que necesitas en caso de accidente, robo o daño en la carretera. Con opciones de cobertura personalizadas y tarifas competitivas, puedes estar tranquilo sabiendo que estás protegido contra los imprevistos mientras mantienes tu flota en movimiento. Confía en nosotros para proteger tus activos y mantener la seguridad de tu negocio en todo momento.
        </p>
        <p slot="after-subsubtitle">
            Nuestros seguros para flotas están diseñados pensando en tu seguridad y tranquilidad al conducir. Confía en nosotros para proteger tu flota.
        </p>
    </SegurosPage>
    <SegurosLink 
    hrefFrom='/seguro-las-palmas/embarcaciones/'
    titleFrom='Embarcaciones'
    hrefTo='/seguro-las-palmas/hogar/'
    titleTo='Hogar'
    />
	<Footer />
</Layout>
