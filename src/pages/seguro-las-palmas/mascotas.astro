---
import Layout from '~/layouts/Layout.astro';
import HeaderTop from '~/components/headerTop.astro';
import Header from '~/components/header.astro';
import Whatsapp from '~/components/whatsapp.astro';
import Footer from '~/components/footer.astro';
import SegurosPage from '~/components/segurosPage.astro';
import SegurosLink from '~/components/segurosLink.astro';
import { buildServiceSchema, siteURL } from '~/utils/schema';

const pageURL = `${siteURL}/seguro-las-palmas/mascotas/`;
const jsonLd = buildServiceSchema({
  pageURL,
  name: "Seguros para Mascotas en Las Palmas",
  description: "Seguros de mascotas en Las Palmas de Gran Canaria. Cobertura veterinaria, responsabilidad civil y asistencia para perros y gatos. Obligatorio para razas PPP.",
  serviceType: "Pet insurance",
  breadcrumbName: "Seguro de Mascotas",
  faqs: [
    { question: "¿Qué cubre el seguro de mascotas?", answer: "Generalmente cubre gastos veterinarios por accidente o enfermedad, responsabilidad civil si tu mascota causa daños a terceros, y en algunas pólizas, deceso y cirugías." },
    { question: "¿Es obligatorio el seguro para perros potencialmente peligrosos (PPP)?", answer: "Sí, en España la Ley 50/1999 exige seguro de responsabilidad civil para tenedores de perros de razas consideradas potencialmente peligrosas." },
    { question: "¿Cubre el seguro de mascotas la responsabilidad civil si mi animal muerde a alguien?", answer: "Sí, la cobertura de RC cubre los daños físicos o materiales que tu mascota pueda causar a terceras personas, incluyendo atenciones médicas." }
  ]
});
---

<Layout
	title="Seguros para Mascotas en Las Palmas"
	description='En Asegura-Te te ayudamos a encontrar el seguro de mascotas adecuado en Las Palmas. Cuida de lo que más quieres.'
	canonicalURL={pageURL}
	>
	<script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(jsonLd)} />
	<Whatsapp />
	<section id="inicio">
		<HeaderTop />
		<Header />
	</section>
    <SegurosPage
        title='Seguros para Mascotas en Las Palmas'
        url="/images/mascotas.webp"
        alt="Seguros para Mascotas en Las Palmas"
        href="/contacto/"
        subtitle='Cuida a tus mascotas con nuestros seguros'
        subsubtitle="¿Por qué elegir nuestros seguros de mascotas en Las Palmas?"
        >
        <p slot="after-title">
			Sabemos que tus mascotas son parte de tu familia, por eso ofrecemos seguros para mascotas en Las Palmas diseñados para brindarte la tranquilidad y protección que necesitas para su cuidado. Nuestros planes de cobertura flexible están diseñados para adaptarse a las necesidades específicas de tu mascota, brindándote la tranquilidad de saber que estás protegido contra los costos asociados con la atención veterinaria y otros gastos inesperados. Confía en nosotros para proteger a tus mascotas y disfrutar de su compañía con total tranquilidad
        </p>
        <p slot="after-subtitle">
            En Asegura-Te nos preocupamos por la salud y el bienestar de tus mascotas tanto como tú, por eso nos dedicamos a proporcionarte la mejor protección en el mercado. Nuestros seguros para mascotas están diseñados para brindarte la cobertura que necesitas en caso de enfermedad, lesión o accidente. Con opciones de cobertura personalizadas y tarifas competitivas, puedes estar tranquilo sabiendo que estás protegido contra los gastos veterinarios y otros costos asociados con el cuidado de tus mascotas. Confía en nosotros para proteger a tus compañeros peludos y mantener su salud y felicidad en todo momento.
        </p>
        <p slot="after-subsubtitle">
            Nuestros seguros para mascotas están diseñados pensando en su salud y bienestar. Confía en nosotros para cuidar de tus compañeros peludos.
        </p>
    </SegurosPage>
    <SegurosLink 
    hrefFrom='/seguro-las-palmas/hogar/'
    titleFrom='Hogar'
    hrefTo='/seguro-las-palmas/motos/'
    titleTo='Motos'
    />
	<Footer />
</Layout>
