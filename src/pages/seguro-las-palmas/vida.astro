---
import Layout from '~/layouts/Layout.astro';
import HeaderTop from '~/components/headerTop.astro';
import Header from '~/components/header.astro';
import Whatsapp from '~/components/whatsapp.astro';
import Footer from '~/components/footer.astro';
import SegurosPage from '~/components/segurosPage.astro';
// import Tarificador from '~/components/tarificador.astro';
import ContactForm from '~/components/contactForm.astro';
import SegurosLink from '~/components/segurosLink.astro';
import { buildServiceSchema, siteURL } from '~/utils/schema';

const pageURL = `${siteURL}/seguro-las-palmas/vida/`;
const jsonLd = buildServiceSchema({
  pageURL,
  name: "Seguros de Vida Riesgo en Las Palmas",
  description: "Seguros de vida riesgo en Las Palmas de Gran Canaria. Protege el futuro financiero de tu familia en caso de fallecimiento, invalidez o enfermedad grave.",
  serviceType: "Life insurance",
  breadcrumbName: "Seguro de Vida",
  faqs: [
    { question: "¿Qué es un seguro de vida riesgo?", answer: "Es un seguro que abona un capital a los beneficiarios designados en caso de fallecimiento del asegurado, y puede incluir coberturas adicionales por invalidez o enfermedad grave." },
    { question: "¿Quién puede ser beneficiario del seguro de vida?", answer: "Cualquier persona física o jurídica designada por el tomador: cónyuge, hijos, otros familiares o incluso una entidad bancaria en caso de préstamos hipotecarios." },
    { question: "¿Es obligatorio el seguro de vida con una hipoteca?", answer: "No es legalmente obligatorio, pero muchas entidades lo recomiendan o vinculan a condiciones ventajosas. Puedes contratarlo con cualquier aseguradora, no necesariamente la del banco." },
    { question: "¿Qué coberturas puede incluir un seguro de vida?", answer: "Fallecimiento por cualquier causa, invalidez permanente total o absoluta, incapacidad temporal, enfermedades graves y doble capital por accidente, entre otras opciones." },
    { question: "¿Qué capital asegurado necesito?", answer: "Depende de tus cargas financieras (hipoteca, préstamos), ingresos familiares y el nivel de protección deseado. Lo habitual es cubrir entre 3 y 10 veces el salario anual." }
  ]
});
---

<Layout
	title="Seguros de Vida Riesgo en Las Palmas"
	description='Protege el futuro de tus seres queridos con nuestros seguros de vida en Las Palmas. Asegura-Te: correduría de seguros con coberturas adaptadas a tus necesidades.'
	canonicalURL={pageURL}
	>
	<script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(jsonLd)} />
	<Whatsapp />
	<section id="inicio">
		<HeaderTop />
		<Header />
	</section>
    <SegurosPage
        title='Seguros de Vida Riesgo en Las Palmas'
        url="/images/vida.webp"
        alt="Seguros de Vida Riesgo en Las Palmas"
        href="#avantContainer"
        subtitle='Protege el futuro de tus seres queridos con nuestros seguros de vida'
        subsubtitle="¿Por qué elegir nuestros seguros de vida?"
        >
        <p slot="after-title">
            En Asegura-Te sabemos que tu familia es tu prioridad número uno, por eso ofrecemos seguros de vida riesgo en Las Palmas diseñados para brindarte la protección y tranquilidad que necesitas para su futuro financiero. Nuestros planes de cobertura flexible están diseñados para adaptarse a las necesidades específicas de tu familia, brindándote la tranquilidad de saber que estás protegido contra los riesgos asociados con la vida cotidiana. Confía en nosotros para proteger a tus seres queridos y mantener su seguridad financiera en caso de tragedia.
        </p>
        <p slot="after-subtitle">
            En Asegura-Te nos preocupamos por el bienestar de tu familia tanto como tú, por eso nos dedicamos a proporcionarte la mejor protección en el mercado. Nuestros seguros de vida riesgo están diseñados para brindarte la cobertura que necesitas en caso de fallecimiento prematuro, incapacidad o enfermedad grave. Con opciones de cobertura personalizadas y tarifas competitivas, puedes estar tranquilo sabiendo que estás protegido contra los riesgos financieros asociados con la vida cotidiana. Confía en nosotros para proteger a tus seres queridos y mantener su seguridad financiera en todo momento.
        </p>
        <p slot="after-subsubtitle">
            Nuestros seguros de vida riesgo están diseñados pensando en la protección y seguridad de tu familia. Confía en nosotros para cuidar de ellos.
        </p>
    </SegurosPage>
    <ContactForm  page="Vida"/>
    <!-- <Tarificador name="vida"/> -->
    <SegurosLink
    hrefFrom='/seguro-las-palmas/viajes/'
    titleFrom='Viajes'
    hrefTo='/seguro-las-palmas/accidentes-convenios/'
    titleTo='Accidente de convenios'
    />
	<Footer />
</Layout>
