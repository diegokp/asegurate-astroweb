---
import Layout from '~/layouts/Layout.astro';
import HeaderTop from '~/components/headerTop.astro';
import Header from '~/components/header.astro';
import Whatsapp from '~/components/whatsapp.astro';
import AboutUs from '~/components/aboutUs.astro';
import Companies from '~/components/companies.astro';
import Footer from '~/components/footer.astro'
import Carrousel from '~/components/carrousel.astro';
import Productos from '~/components/productos.vue';
import Preguntas from '~/components/preguntas.vue'

const siteURL = "https://www.aseguratte.es";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteURL}/#website`,
      "url": siteURL,
      "name": "Asegura-Te",
      "description": "Correduría de Seguros en Las Palmas de Gran Canaria. Seguros de hogar, coche, salud, vida y más para particulares y empresas.",
      "inLanguage": "es",
      "publisher": { "@id": `${siteURL}/#agency` }
    },
    {
      "@type": "WebPage",
      "@id": `${siteURL}/#webpage`,
      "url": siteURL,
      "name": "Correduría de Seguros en Las Palmas | Asegura-Te",
      "isPartOf": { "@id": `${siteURL}/#website` },
      "about": { "@id": `${siteURL}/#agency` },
      "inLanguage": "es"
    }
  ]
};
---

<Layout
	title=""
	description=""
	canonicalURL={siteURL}
	>
	<script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(jsonLd)} />
	<Whatsapp />
	<section id="inicio">
		<HeaderTop />
		<Header />
		<Carrousel />
	</section>
	<AboutUs />
	<Productos client:only="vue"/>
	<Companies />
	<Preguntas client:only="vue" />
	<Footer />
</Layout>
